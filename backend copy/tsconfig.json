{
  
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
   "outDir":"./dist",
   "rootDir":"./src",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
   "esModuleInterop": true,
   "strictPropertyInitialization": false,
    "skipLibCheck": true,
  },
  "include":["./src/**/*.ts"],
  "exclude":["./dist","node_modules"]
}
